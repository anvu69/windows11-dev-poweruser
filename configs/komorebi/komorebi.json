{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/master/schema.json",
  "default_workspace_padding": 8,
  "default_container_padding": 6,
  "border": true,
  "border_width": 2,
  "monitors": [
    {
      "workspaces": [
        { "name": "term", "layout": "BSP" },
        { "name": "web", "layout": "BSP" },
        { "name": "ssh", "layout": "BSP" },
        { "name": "db", "layout": "BSP" },
        { "name": "docs", "layout": "BSP" },
        { "name": "chat", "layout": "BSP" },
        { "name": "monitor", "layout": "BSP" },
        { "name": "media", "layout": "BSP" },
        { "name": "misc", "layout": "BSP" }
      ]
    }
  ],
  "float_rules": [
    { "kind": "Exe", "id": "Bitwarden.exe" },
    { "kind": "Exe", "id": "electerm.exe" },
    { "kind": "Exe", "id": "DBeaver.exe" }
  ]
}