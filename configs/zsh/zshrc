# Zsh config for WSL2 AlmaLinux power-user workflow
# Uses Oh My Zsh when installed, but remains usable without it.

export ZSH="$HOME/.oh-my-zsh"
export EDITOR=nvim
export VISUAL=nvim
export PAGER=less

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt appendhistory sharehistory hist_ignore_dups hist_ignore_space hist_reduce_blanks
setopt autocd extendedglob nomatch notify

# Oh My Zsh
ZSH_THEME="robbyrussell"
plugins=(
  git
  sudo
  ssh-agent
  fzf
  zoxide
  colored-man-pages
  command-not-found
)

if [ -s "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# Vi mode after OMZ load so it wins over plugin defaults.
bindkey -v
export KEYTIMEOUT=1

# CLI integrations
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf >/dev/null 2>&1; then
  if [ -f /usr/share/fzf/shell/key-bindings.zsh ]; then
    source /usr/share/fzf/shell/key-bindings.zsh
  fi
  if [ -f /usr/share/fzf/shell/completion.zsh ]; then
    source /usr/share/fzf/shell/completion.zsh
  fi
fi

# Local aliases/functions
[ -f "$HOME/.config/zsh/aliases.zsh" ] && source "$HOME/.config/zsh/aliases.zsh"

# User-local bin paths
export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"
